# ============================================
# Beancount Bot Docker 环境变量配置
# ============================================

# --------------------------------------------
# Docker 配置
# --------------------------------------------
# Docker Hub 用户名（用于镜像名称）
DOCKER_USERNAME=wangweitung

# --------------------------------------------
# 基础配置
# --------------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --------------------------------------------
# Telegram 配置（必填）
# --------------------------------------------
TG_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_chat_id_here
# Telegram 代理（留空表示不使用代理）
TG_PROXY=http://10.1.1.3:7890

# --------------------------------------------
# Gotify 配置（可选）
# --------------------------------------------
# GOTIFY_URL=https://your-gotify-server
# GOTIFY_TOKEN=your_gotify_token_here
# GOTIFY_PRIORITY=5

# --------------------------------------------
# 推送配置
# --------------------------------------------
# 可选值: telegram, gotify, all
NOTIFY_TARGETS=telegram

# --------------------------------------------
# 代理配置
# --------------------------------------------
PROXY_URL=http://10.1.1.3:7890

# --------------------------------------------
# 鉴权配置（必填）
# 首次使用机器人时需要输入此令牌
# --------------------------------------------
AUTH_TOKEN=your_auth_token_here

# --------------------------------------------
# 文件路径配置
# --------------------------------------------
# 机器人会话文件路径（保存登录状态）
SESSION_FILE=/app/bot.session
# 账本文件路径（支持 {year} {month} {date} 变量）
BEANCOUNT_FILE=/bean/{year}-{month}月/{month}月交易.bean
# 模板配置文件路径
TEMPLATE_CONFIG=/config/template.yml

# --------------------------------------------
# 定时任务配置
# --------------------------------------------
# 股价更新任务执行时间（24小时制）
PRICE_TIME=21:30
# 股价更新完成消息
PRICE_DONE_MESSAGE=价格更新完成
